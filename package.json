{
  "name": "straxio",
  "version": "1.2.0",
  "description": "Ethereum & Tron wallet monitor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build": "electron-builder --publish never"
  },
  "build": {
    "appId": "com.straxio.app",
    "productName": "Straxio",
    "afterPack": "./afterPack.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "straxio_3.html"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "win": {
      "target": [
        { "target": "zip", "arch": ["x64"] }
      ]
    }
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0"
  }
}
